# 统一换行符为 LF
* text=auto

# Java 源文件
*.java text eol=lf

# 前端源文件
*.ts text eol=lf
*.vue text eol=lf
*.css text eol=lf
*.html text eol=lf

# 配置文件
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.properties text eol=lf
*.json text eol=lf
*.jsonc text eol=lf

# Shell 脚本
*.sh text eol=lf

# Docker
Dockerfile text eol=lf
Dockerfile.* text eol=lf
*.dockerfile text eol=lf

# Markdown
*.md text eol=lf

# 二进制文件（不进行换行处理）
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
